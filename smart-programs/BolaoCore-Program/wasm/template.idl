type Score = struct {
  home: u8,
  away: u8,
};

type PenaltyWinner = enum {
  Home,
  Away,
};

type UserBetView = struct {
  match_id: u64,
  score: Score,
  penalty_winner: opt PenaltyWinner,
  stake_in_match_pool: u128,
  claimed: bool,
};

type FinalPrizeClaimStatus = struct {
  wallet: actor_id,
  final_prize_finalized: bool,
  eligible: bool,
  amount_claimable: u128,
  already_claimed: bool,
  points: u32,
};

type Match = struct {
  match_id: u64,
  phase: str,
  home: str,
  away: str,
  kick_off: u64,
  result: ResultStatus,
  match_prize_pool: u128,
  has_bets: bool,
  participants: vec actor_id,
  total_winner_stake: u128,
  total_claimed: u128,
  settlement_prepared: bool,
  dust_swept: bool,
};

type ResultStatus = enum {
  Unresolved,
  Proposed: struct {
    score: Score,
    penalty_winner: opt PenaltyWinner,
    oracle: actor_id,
  },
  Finalized: struct {
    score: Score,
    penalty_winner: opt PenaltyWinner,
  },
};

type IoSmartCupState = struct {
  admin: actor_id,
  protocol_fee_accumulated: u128,
  final_prize_accumulated: u128,
  matches: vec Match,
  phases: vec PhaseConfig,
  user_points: vec struct { actor_id, u32 },
  podium_finalized: bool,
  r32_lock_time: opt u64,
  final_prize_finalized: bool,
  final_prize_claimable_total: u128,
  final_prize_rounding_dust: u128,
};

type PhaseConfig = struct {
  name: str,
  start_time: u64,
  end_time: u64,
  points_weight: u32,
};

type WalletClaimStatus = struct {
  wallet: actor_id,
  amount_claimable: u128,
  already_claimed: bool,
};

constructor {
  New : (admin: actor_id);
};

service Service {
  /// Step 2 of 2-step admin transfer: pending admin confirms ownership.
  /// Must be called by the address previously set via change_admin().
  AcceptAdmin : () -> SmartCupEvent;
  CancelProposedResult : (match_id: u64) -> SmartCupEvent;
  /// Step 1 of 2-step admin transfer: proposes a new admin address.
  /// The proposed address must call accept_admin() to complete the transfer.
  ChangeAdmin : (new_admin: actor_id) -> SmartCupEvent;
  ClaimFinalPrize : () -> SmartCupEvent;
  ClaimMatchReward : (match_id: u64) -> SmartCupEvent;
  FinalizeFinalPrizePool : () -> SmartCupEvent;
  FinalizePodium : (champion: str, runner_up: str, third_place: str) -> vec SmartCupEvent;
  FinalizeResult : (match_id: u64) -> SmartCupEvent;
  PlaceBet : (match_id: u64, predicted_score: Score, predicted_penalty_winner: opt PenaltyWinner) -> SmartCupEvent;
  PrepareMatchSettlement : (match_id: u64) -> SmartCupEvent;
  ProposeResult : (match_id: u64, final_score: Score, penalty_winner: opt PenaltyWinner) -> SmartCupEvent;
  RegisterMatch : (phase: str, home: str, away: str, kick_off: u64) -> SmartCupEvent;
  RegisterPhase : (phase_name: str, start_time: u64, end_time: u64, points_weight: u32) -> SmartCupEvent;
  SetOracleAuthorized : (oracle: actor_id, authorized: bool) -> SmartCupEvent;
  SubmitPodiumPick : (champion: str, runner_up: str, third_place: str) -> SmartCupEvent;
  SweepMatchDustToFinalPrize : (match_id: u64) -> SmartCupEvent;
  WithdrawFinalPrizeRoundingDust : () -> SmartCupEvent;
  WithdrawProtocolFees : () -> SmartCupEvent;
  query QueryBetsByUser : (user: actor_id) -> vec UserBetView;
  query QueryFinalPrizeClaimStatus : (wallet: actor_id) -> FinalPrizeClaimStatus;
  query QueryMatch : (match_id: u64) -> opt Match;
  query QueryMatchesByPhase : (phase: str) -> vec Match;
  query QueryState : () -> IoSmartCupState;
  query QueryUserPoints : (user: actor_id) -> u32;
  query QueryWalletClaimStatus : (wallet: actor_id) -> WalletClaimStatus;

  events {
    PhaseRegistered: str;
    MatchRegistered: struct {
      u64,
      str,
      str,
      str,
      u64,
    };
    OracleAuthorized: struct {
      actor_id,
      bool,
    };
    BetAccepted: struct {
      actor_id,
      u64,
      Score,
      opt PenaltyWinner,
      u128,
    };
    ResultProposed: struct {
      u64,
      Score,
      opt PenaltyWinner,
      actor_id,
    };
    ResultFinalized: struct {
      u64,
      Score,
      opt PenaltyWinner,
    };
    SettlementPrepared: struct {
      u64,
      u128,
    };
    PointsAwarded: struct {
      actor_id,
      u64,
      u32,
    };
    MatchRewardClaimed: struct {
      u64,
      actor_id,
      u128,
    };
    MatchDustSwept: struct {
      u64,
      u128,
    };
    PodiumPickSubmitted: struct {
      actor_id,
      str,
      str,
      str,
    };
    PodiumFinalized: struct {
      str,
      str,
      str,
    };
    PodiumBonusAwarded: struct {
      actor_id,
      u32,
    };
    FinalPrizeSent: struct {
      u128,
      actor_id,
    };
    ProtocolFeesWithdrawn: struct {
      u128,
      actor_id,
    };
    AdminProposed: struct {
      actor_id,
      actor_id,
    };
    AdminChanged: struct {
      actor_id,
      actor_id,
    };
    FinalPrizePoolFinalized: struct {
      u128,
      u128,
    };
    FinalPrizeClaimed: struct {
      actor_id,
      u128,
    };
    FinalPrizeRoundingDustWithdrawn: struct {
      u128,
      actor_id,
    };
    ResultProposalCancelled: struct {
      u64,
      actor_id,
    };
  }
};

